{
  "name": "parabank-automation",
  "version": "1.0.0",
  "description": "BDD Automation for ParaBank Sign-Up & Login using Playwright + Cucumber + TypeScript",
  "scripts": {
    "setup": "npm install && npx playwright install chromium",
    "test": "cucumber-js",
    "test:report": "cucumber-js --format html:reports/cucumber-report.html",
    "test:headed": "HEADLESS=false cucumber-js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.7",
    "dotenv": "^16.4.5",
    "playwright": "^1.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
